/* SPDX-License-Identifier: Apache-2.0 */
/*
 * app.overlay — Devicetree hardware overlay for the phone
 *
 * This file is merged (overlaid) on top of the board's base devicetree
 * (nucleo_h753zi.dts) at build time. It describes phone-specific
 * hardware that is attached to the Nucleo board's peripherals.
 *
 * The board already defines: USART3 (console), LPUART1, USB OTG_FS,
 * I2C1, I2C2, SPI1, 2 LEDs, 1 user button, and flash partitions.
 *
 * This overlay will grow as we add peripherals:
 *   - Modem UART: LPUART1 (already in board DTS, PB6/PB7, 115200)
 *     + PWRKEY/STATUS GPIO (to be added)
 *   - Keypad matrix (5x4 = 9 GPIO pins)
 *   - ST7789V display on SPI1 (CS, DC, reset, backlight pins)
 *   - MAX9880A codec + MAX17048 fuel gauge on I2C1
 *
 * The modem UART (LPUART1) is already configured in the board DTS —
 * no overlay changes needed for it. PWRKEY and STATUS GPIOs will be
 * added here when we wire up modem power control.
 */

#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>
#include <zephyr/dt-bindings/gpio/arduino-header-r3.h>
#include <zephyr/dt-bindings/display/panel.h>

/* Disable the B1 user button (PC13) — we removed B1 from app code
 * (the keypad's A/B keys replaced it), but the board DTS still
 * defines the user_button node and the gpio-keys driver claims
 * PC13/EXTI13 at boot. Our keypad row 0 is PE13, which also needs
 * EXTI13. STM32 EXTI lines are port-shared — only one port per
 * line — so PC13's claim blocks PE13 with -EBUSY. Disabling the
 * user_button node frees EXTI13 for PE13. */
&user_button {
    status = "disabled";
};

/ {
    chosen {
        zephyr,display = &st7789v_lcd;
    };

    /* ST7789V 2.0" 240×320 color TFT display (Waveshare 2inch LCD Module)
     *
     * Wiring (LCD → Nucleo Arduino header):
     *   VCC → 3.3V
     *   GND → GND
     *   DIN → D11 (PB5, SPI1 MOSI)
     *   CLK → D13 (PA5, SPI1 SCK)
     *   CS  → D10 (PD14, SPI1 CS — already in board DTS)
     *   DS  → D9  (PD15, Data/Command)
     *   RST → D8  (PF3,  Reset, active low)
     *   BL  → D7  (PG12, Backlight, active high)
     *
     * The MIPI DBI SPI wrapper (zephyr,mipi-dbi-spi) sits between the
     * SPI controller and the display panel. It handles the DC pin
     * (data/command) and reset pin, translating Zephyr's display API
     * calls into SPI transactions with the right DC state. */
    mipi_dbi_lcd: mipi-dbi-lcd {
        compatible = "zephyr,mipi-dbi-spi";
        spi-dev = <&spi1>;
        dc-gpios = <&arduino_header ARDUINO_HEADER_R3_D9 GPIO_ACTIVE_HIGH>;
        reset-gpios = <&arduino_header ARDUINO_HEADER_R3_D8 GPIO_ACTIVE_LOW>;
        write-only;
        #address-cells = <1>;
        #size-cells = <0>;

        st7789v_lcd: st7789v@0 {
            compatible = "sitronix,st7789v";
            mipi-max-frequency = <20000000>;
            reg = <0>;
            width = <240>;
            height = <320>;
            x-offset = <0>;
            y-offset = <0>;
            vcom = <0x19>;
            gctrl = <0x35>;
            vrhs = <0x12>;
            vdvs = <0x20>;
            mdac = <0x00>;
            gamma = <0x01>;
            pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
            lcm = <0x2c>;
            porch-param = [0c 0c 00 33 33];
            cmd2en-param = [5a 69 02 01];
            pwctrl1-param = [a4 a1];
            pvgam-param = [d0 04 0d 11 13 2b 3f 54 4c 18 0d 0b 1f 23];
            nvgam-param = [d0 04 0c 11 13 2c 3f 44 51 2f 1f 1f 20 23];
            ram-param = [00 f0];
            rgb-param = [cd 08 14];
            mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE";
        };
    };

    /* Backlight GPIO — controlled via regulator-fixed.
     * Active high: set high to turn on the backlight.
     * regulator-boot-on ensures it's on at boot. */
    lcd_backlight: lcd-backlight {
        compatible = "regulator-fixed";
        enable-gpios = <&arduino_header ARDUINO_HEADER_R3_D7 GPIO_ACTIVE_HIGH>;
        regulator-name = "lcd-backlight";
        regulator-boot-on;
        startup-delay-us = <10000>;
    };

    /* 4x4 matrix keypad (Adafruit PID 3844 membrane keypad)
     *
     * Wiring (keypad → Nucleo Arduino header):
     *   R1 → D3  (PE13, row 0)
     *   R2 → D4  (PE14, row 1)
     *   R3 → D5  (PE11, row 2)
     *   R4 → D6  (PE9,  row 3)
     *   C1 → A1  (PC0,  col 0)
     *   C2 → A2  (PC3,  col 1)
     *   C3 → A3  (PB1,  col 2)
     *   C4 → D2  (PG14, col 3)
     *
     * Rows are inputs with internal pull-ups (active low): a pressed
     * key connects the row to the currently-driven column, which the
     * driver pulls low during that column's scan slot. Unselected
     * columns are high-impedance (input) so they don't interfere.
     *
     * idle-mode = "interrupt" — the driver sleeps with row-pin EXTI
     * interrupts armed; a keypress wakes it instantly. Zero CPU until
     * a key is pressed. This is the default and most efficient mode.
     *
     * The driver runs in its own thread (CONFIG_INPUT_KBD_MATRIX_THREAD_*
     * defaults) and emits input events: INPUT_ABS_X = column,
     * INPUT_ABS_Y = row, INPUT_BTN_TOUCH = pressed/released. The app
     * registers an INPUT_CALLBACK_DEFINE() callback to receive them.
     *
     * Keymap (Adafruit 4x4 membrane layout):
     *        C1  C2  C3  C4
     *   R1:  1   2   3   A
     *   R2:  4   5   6   B
     *   R3:  7   8   9   C
     *   R4:  *   0   #   D
     */
    kbd_matrix: kbd-matrix {
        compatible = "gpio-kbd-matrix";
        row-gpios = <&arduino_header ARDUINO_HEADER_R3_D3 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>,
                    <&arduino_header ARDUINO_HEADER_R3_D4 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>,
                    <&arduino_header ARDUINO_HEADER_R3_D5 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>,
                    <&arduino_header ARDUINO_HEADER_R3_D6 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
        col-gpios = <&arduino_header ARDUINO_HEADER_R3_A1 GPIO_ACTIVE_LOW>,
                    <&arduino_header ARDUINO_HEADER_R3_A2 GPIO_ACTIVE_LOW>,
                    <&arduino_header ARDUINO_HEADER_R3_A3 GPIO_ACTIVE_LOW>,
                    <&arduino_header ARDUINO_HEADER_R3_D2 GPIO_ACTIVE_LOW>;
        debounce-down-ms = <10>;
        debounce-up-ms = <20>;
        poll-timeout-ms = <100>;
        idle-mode = "interrupt";
    };
};
